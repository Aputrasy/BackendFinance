# Database Configuration
DB_SERVER=your-server-name
DB_DATABASE=your-database-name
DB_USER=your-username
DB_PASSWORD=your-password
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
# Option 1: Use JWT (Dynamic Token - Default)
JWT_SECRET=b8fc25e2c1d926bab915a33d07cbb4078d61d315566f685d906fe54ab8dd93a786ffe661ee3cf8ac05f7f8ff232076113f04618eb5366d90247db24757796e84

# Option 2: Use Static Token (Fixed Token - For Development/Testing)
# Set USE_STATIC_TOKEN=true to enable static token mode
USE_STATIC_TOKEN=false
STATIC_TOKEN=your-static-api-token-123456789

# CORS Configuration
# For localhost: http://localhost:3000
# For production: https://yourdomain.com
# For multiple origins: http://localhost:3000,https://yourdomain.com
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
